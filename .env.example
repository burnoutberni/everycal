# EveryCal Server Configuration
# Copy this file to .env and adjust values for your deployment.

# Base URL — the public URL where the server is accessible (no trailing slash)
BASE_URL=https://events.example.com

# Calendar feed token signing secret (required in production)
# Used to derive deterministic private calendar URLs without storing raw tokens.
CALENDAR_FEED_TOKEN_SECRET=replace-with-a-long-random-secret

# Port the server listens on
PORT=3000

# Jobs (scrapers, reminders) — API base URL for scrapers to sync events
# When RUN_JOBS_INTERNALLY=true (Docker default), use http://localhost:3000
JOBS_API_SERVER=http://localhost:3000

# SQLite database path
DATABASE_PATH=/full/path/to/everycal.db

# Upload directory for images
UPLOAD_DIR=/full/path/to/uploads

# OG images directory
OG_DIR=/full/path/to/og-images

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=https://events.example.com,https://www.example.com

# Set to "true" when behind a reverse proxy (nginx, cloudflare, etc.)
# This tells the rate limiter to trust X-Forwarded-For headers.
TRUSTED_PROXY=true

# Open registration — set to "false" to disable public sign-ups
OPEN_REGISTRATIONS=true

# Unsplash API — optional; for header image search (get key at unsplash.com/oauth/applications)
# Without this, Openverse is used as fallback.
# UNSPLASH_ACCESS_KEY=your_access_key

# Skip HTTP Signature verification on incoming ActivityPub requests
# Only use during initial development/testing!
# SKIP_SIGNATURE_VERIFY=true

# SMTP — configure for your mail server. Works with any SMTP provider.
# In non-production, if SMTP is not configured, verification/email-change/reset links are logged to server output.
# In production, configure SMTP to avoid broken auth email flows.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EveryCal <noreply@yourdomain.com>

# BASE_URL should match the app URL so logged verification/reset links are usable.
# Legacy dev toggle (not required for non-production link logging)
# SKIP_EMAIL_VERIFICATION=true

# OIDC SSO (optional; disabled by default). Generic OpenID Connect providers such as Authentik work with these fields.
OIDC_ENABLED=false
OIDC_PROVIDER_KEY=primary_oidc
# OIDC_ISSUER_URL=https://idp.example.com/application/o/everycal/
# OIDC_CLIENT_ID=everycal
# OIDC_CLIENT_SECRET=replace-with-provider-secret
# Defaults to ${BASE_URL}/api/v1/auth/oidc/callback when omitted.
# OIDC_REDIRECT_URI=https://events.example.com/api/v1/auth/oidc/callback
OIDC_SCOPES="openid profile email"
# Optional RP-initiated logout redirect. Some providers require id_token_hint; EveryCal does not retain ID tokens for v1.
# OIDC_POST_LOGOUT_REDIRECT_URI=https://events.example.com/
OIDC_JIT_PROVISIONING=false
OIDC_SYNC_CLAIMS_ON_LOGIN=true
OIDC_SYNC_ADMIN=false
OIDC_SYNC_ROLES=false
OIDC_CLAIM_EMAIL=email
OIDC_CLAIM_EMAIL_VERIFIED=email_verified
OIDC_CLAIM_NAME=name
OIDC_CLAIM_USERNAME=preferred_username
OIDC_CLAIM_AVATAR=picture
OIDC_CLAIM_ADMIN=is_admin
OIDC_CLAIM_ROLES=roles

# Local auth posture. Existing sessions and API keys continue to work when password auth is disabled.
DISABLE_LOCAL_PASSWORD_AUTH=false
DISABLE_LOCAL_REGISTRATION=false
