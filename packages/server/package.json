{
  "name": "@everycal/server",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "cross-env NODE_ENV=development node --watch-path=src --import tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc -b --pretty false",
    "dev:unified": "cross-env NODE_ENV=development node --watch-path=src --import tsx src/unified-index.ts",
    "start:unified": "node dist/unified-index.js"
  },
  "dependencies": {
    "@everycal/core": "workspace:*",
    "@everycal/og": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.2",
    "nanoid": "^5.1.0",
    "nodemailer": "^7.0.11",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "vike": "^0.4.255",
    "@everycal/runtime-core": "workspace:*"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/nodemailer": "^7.0.11",
    "@types/sanitize-html": "^2.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
