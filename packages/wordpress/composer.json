{
  "name": "everycal/wordpress-plugin",
  "description": "Developer tooling for the EveryCal WordPress plugin",
  "type": "project",
  "license": "AGPL-3.0-only",
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "phpstan/phpstan": "^1.12",
    "squizlabs/php_codesniffer": "^3.10",
    "szepeviktor/phpstan-wordpress": "^1.3.5",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "scripts": {
    "lint:phpcs": "phpcs --standard=phpcs.xml.dist",
    "lint:phpstan": "php -d memory_limit=2G vendor/bin/phpstan analyse --configuration=phpstan.neon --memory-limit=2G --no-progress",
    "lint": [
      "@lint:phpcs",
      "@lint:phpstan"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
