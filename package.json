{
  "name": "everycal",
  "private": true,
  "description": "Federated event calendar built on ActivityPub",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "bcrypt",
      "better-sqlite3",
      "core-js",
      "core-js-pure",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "minimatch": ">=10.2.3",
      "webpack-dev-server": ">=5.2.1",
      "ajv": ">=8.18.0",
      "@eslint/eslintrc>ajv": ">=6.14.0",
      "eslint>ajv": ">=6.14.0",
      "qs": ">=6.14.2",
      "basic-ftp": ">=5.2.2",
      "wait-on>axios": ">=1.15.0",
      "vitest>vite": ">=7.3.2",
      "rollup": ">=4.59.0",
      "serialize-javascript": ">=7.0.3",
      "svgo": ">=3.3.3",
      "immutable": ">=5.1.5",
      "picomatch": ">=4.0.4"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @everycal/server dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "job": "node packages/jobs/dist/index.js",
    "job:scrapers": "node packages/jobs/dist/index.js scrapers",
    "job:reminders": "node packages/jobs/dist/index.js reminders",
    "job:scrapers:once": "node packages/jobs/dist/index.js scrapers --once",
    "job:reminders:once": "node packages/jobs/dist/index.js reminders --once"
  }
}
